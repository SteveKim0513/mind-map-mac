{
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git stash*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push*)",
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git show*)",
      "Bash(git tag*)",
      "Bash(npm run typecheck*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run dist*)",
      "Bash(APPLE_KEYCHAIN_PROFILE=* npm run dist*)",
      "Bash(make verify*)",
      "Bash(make test*)",
      "Bash(make typecheck*)",
      "Bash(make harness-check*)",
      "Bash(make setup*)",
      "Bash(node scripts/harness/*)",
      "Bash(ls*)",
      "Bash(find . *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(mkdir -p *)",
      "Bash(chmod +x .claude/hooks/*)",
      "Bash(gh release*)",
      "Bash(gh auth switch*)",
      "Bash(gh auth status*)",
      "Bash(rm -rf release/mac-arm64*)",
      "Bash(rm -rf release-dev/mac-arm64*)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f *)",
      "Bash(git reset --hard*)",
      "Bash(git checkout -- .)",
      "Bash(git branch -D*)",
      "Bash(git tag -d*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/block-destructive-command.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/check-docs-before-commit.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/protect-sensitive-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/format-changed-files.sh"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/remind-doc-index.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/verify-before-stop.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/save-context.sh"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/restore-context.sh"
          }
        ]
      }
    ]
  }
}

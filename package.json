{
  "name": "mind-map",
  "version": "0.7.9",
  "description": "A keyboard-first mind mapping app for macOS",
  "main": "dist-electron/main.js",
  "author": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --config.extraMetadata.productName=MindMap",
    "dist:dev": "npm run build && electron-builder --config.productName='MindMap Dev' --config.extraMetadata.productName='MindMap Dev' --config.appId=co.imaginefutures.mindmap.dev --config.mac.icon=build/icon-dev.icns --config.mac.target=dmg --config.directories.output=release-dev",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@tiptap/extension-image": "^3.26.0",
    "@tiptap/extension-link": "^3.26.0",
    "@tiptap/extension-placeholder": "^3.26.0",
    "@tiptap/extension-table": "^3.26.0",
    "@tiptap/extension-table-cell": "^3.26.0",
    "@tiptap/extension-table-header": "^3.26.0",
    "@tiptap/extension-table-row": "^3.26.0",
    "@tiptap/extension-task-item": "^3.26.0",
    "@tiptap/extension-task-list": "^3.26.0",
    "@tiptap/pm": "^3.26.0",
    "@tiptap/react": "^3.26.0",
    "@tiptap/starter-kit": "^3.26.0",
    "d3-hierarchy": "^3.1.2",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "pretendard": "^1.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tiptap-markdown": "^0.9.0",
    "turndown": "^7.2.4",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/d3-hierarchy": "^3.1.7",
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.8"
  },
  "build": {
    "appId": "co.imaginefutures.mindmap",
    "productName": "MindMap",
    "extraMetadata": {
      "productName": "MindMap"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "notarize": true
    },
    "publish": {
      "provider": "github",
      "owner": "SteveKim0513",
      "repo": "mind-map-mac"
    }
  }
}
